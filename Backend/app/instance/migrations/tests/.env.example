# Flask Core
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-this-secret-key

# Server
HOST=0.0.0.0
PORT=5000

# Database (MySQL)
# DATABASE_URL takes priority if set (used by most PaaS providers, e.g. Render).
DB_HOST=localhost
DB_PORT=3306
DB_NAME=schemehub_db
DB_USER=root
DB_PASSWORD=change-this-password
DATABASE_URL=mysql+pymysql://root:change-this-password@localhost:3306/schemehub_db
SQLALCHEMY_DATABASE_URI=mysql+pymysql://root:change-this-password@localhost:3306/schemehub_db

# JWT
JWT_SECRET_KEY=change-this-jwt-secret
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key-here

# Uploads
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=10485760

# CORS
CORS_ORIGINS=http://localhost:3000

# Logging
LOG_LEVEL=INFO
LOG_FOLDER=logs
